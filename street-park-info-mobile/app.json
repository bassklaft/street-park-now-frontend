{
  "expo": {
    "name": "Street Park Now",
    "slug": "street-park-info-mobile",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#080808"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bassklaft.streetparkinfomobile",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSLocationWhenInUseUsageDescription": "Street Park Now uses your location to find nearby street cleaning schedules, parking restrictions, and film permits so you know exactly when to move your car to avoid tickets. For example, if you're parked on Bedford Avenue in Brooklyn, we'll show you that street cleaning happens Monday and Thursday 8–9:30 AM."
      },
      "buildNumber": "4"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#080808"
      }
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "787c1d1f-fd03-4721-8bbc-fe48c4f14572"
      }
    }
  }
}
